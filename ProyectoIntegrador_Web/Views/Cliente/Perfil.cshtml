@model ProyectoIntegrador_Web.Models.EditarClienteViewModel

@{
    ViewData["Title"] = "Perfil";
}

<div class="container py-5">

    <div class="text-center mb-4">
        <h2 class="fw-bold mb-1">Mi Perfil</h2>
        <p class="text-muted mb-0">Actualizá tus datos personales y gestioná tu cuenta</p>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-action="Perfil" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">

            <!-- COLUMNA IZQUIERDA -->
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 rounded-4 h-100">
                    <div class="card-body text-center p-4">

                        <img id="fotoPerfilCliente"
                             src="@(string.IsNullOrEmpty(Model.Foto)
                                                              ? "/images/usuarios/default-image.jpg"
                                                              : Model.Foto)"
                             class="img-thumbnail shadow-sm mb-3 foto-perfil" />

                        <h5 class="fw-semibold mb-1">@Model.Nombre @Model.Apellido</h5>
                        <p class="text-muted small mb-3">@Model.Email</p>

                        <label class="btn btn-outline-secondary btn-sm">
                            Seleccionar foto
                            <input id="archivoFotoCliente" type="file" name="archivoFotoCliente" accept="image/*" hidden />
                        </label>

                        <div id="archivoImagenSeleccionado" class="mt-2 text-muted small"></div>

                        <input type="hidden" asp-for="Foto" />

                        <hr class="my-4" />

                        <div class="d-grid gap-2">
                            <a asp-action="Inicio" class="btn btn-outline-secondary">
                                Volver
                            </a>

                            <a asp-controller="Usuario"
                               asp-action="CambioContra"
                               asp-route-returnUrl="/Cliente/Perfil"
                               class="btn btn-outline-dark">
                                Nueva contraseña
                            </a>

                            <button type="button"
                                    class="btn btn-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#modalEliminarCuenta"
                                    onclick="pedirCodigoEliminar()">
                                Eliminar cuenta
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- COLUMNA DERECHA -->
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body p-4">

                        <h4 class="fw-semibold mb-4">Datos personales</h4>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Nombre" class="form-label fw-semibold"></label>
                                <input asp-for="Nombre" class="form-control" placeholder="Tu nombre" />
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Apellido" class="form-label fw-semibold"></label>
                                <input asp-for="Apellido" class="form-control" placeholder="Tu apellido" />
                                <span asp-validation-for="Apellido" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Email" class="form-label fw-semibold"></label>
                                <input asp-for="Email" class="form-control bg-light" readonly />
                            </div>
                        </div>

                        <hr class="my-4" />

                        <h4 class="fw-semibold mb-4">Dirección</h4>

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="Domicilio" class="form-label fw-semibold"></label>
                                <input asp-for="Domicilio" class="form-control" placeholder="Calle y número" />
                                <span asp-validation-for="Domicilio" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Departamento" class="form-label fw-semibold"></label>
                                <select asp-for="Departamento"
                                        class="form-select"
                                        asp-items="@(new SelectList(Model.DepartamentosOpciones))">
                                </select>
                                <span asp-validation-for="Departamento" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Barrio" class="form-label fw-semibold"></label>
                                <input asp-for="Barrio" class="form-control" placeholder="Barrio o zona" />
                                <span asp-validation-for="Barrio" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mt-4">
                            <button type="submit" class="btn btn-primary px-4">
                                Guardar cambios
                            </button>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </form>

    <hr class="my-5" />

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h4 class="fw-semibold mb-1">Artesanos que seguís</h4>
            <p class="text-muted mb-0 small">Accedé rápido a sus perfiles o dejá de seguirlos</p>
        </div>
    </div>

    @if (Model.ListaSeguidores?.listaDeArtesanos.Any() == true)
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @foreach (var artesano in Model.ListaSeguidores.listaDeArtesanos)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded-4">
                        <div class="card-body text-center p-4">

                            <img src="@(string.IsNullOrEmpty(artesano.foto)
                                                                  ? "/images/usuarios/default-image.jpg"
                                                                  : artesano.foto)"
                         class="rounded-circle mb-3 shadow-sm"
                         style="width:100px;height:100px;object-fit:cover;" />

                            <h5 class="card-title mb-1">@artesano.nombre</h5>
                            <p class="text-muted small mb-3">@artesano.apellido</p>

                            <div class="d-grid gap-2">
                                <a asp-controller="Usuario"
                                   asp-action="PerfilPublico"
                                   asp-route-id="@artesano.id"
                                   class="btn btn-outline-primary btn-sm">
                                    Ver perfil
                                </a>

                                <form asp-controller="Cliente"
                                      asp-action="DejarDeSeguir"
                                      method="post"
                                      class="d-inline">
                                    <input type="hidden" name="artesanoId" value="@artesano.id" />
                                    <button type="submit" class="btn btn-danger btn-sm w-100">
                                        Dejar de seguir
                                    </button>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
                }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body text-center py-5">
                <p class="text-muted mb-0">Aún no seguís a ningún artesano.</p>
            </div>
        </div>
    }

    @await Html.PartialAsync("_ModalEliminarCuenta", Model.EliminarCuenta)

    <script>
        function pedirCodigoEliminar() {
            fetch('/Cliente/PedirCodigoEliminar', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken':
                        document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            });
        }
    </script>

    <script>
        const input = document.getElementById("archivoFotoCliente");
        const preview = document.getElementById("fotoPerfilCliente");
        const archivoLabel = document.getElementById("archivoImagenSeleccionado");

        input.addEventListener("change", function () {
            if (this.files && this.files[0]) {
                const archivo = this.files[0];
                archivoLabel.innerHTML = `<strong>${archivo.name}</strong>`;

                const reader = new FileReader();
                reader.onload = e => preview.src = e.target.result;
                reader.readAsDataURL(archivo);
            }
        });
    </script>

    @if (TempData["ErrorEliminar"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const modal = new bootstrap.Modal(
                    document.getElementById("modalEliminarCuenta")
                );
                modal.show();
            });
        </script>
    }
</div>
