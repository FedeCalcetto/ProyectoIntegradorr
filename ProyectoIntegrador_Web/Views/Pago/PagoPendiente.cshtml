@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory factory

@{
    var localizer = factory.Create("Resource", "ProyectoIntegrador_Web");
}
<h2>⏳ @localizer["PagoEnProceso"]</h2>

<p>
    @localizer["PagoEnProcesoDescripcion"]
</p>

<p>
    <strong>@localizer["Orden"]:</strong> @Model.Id <br />
    <strong>@localizer["Estado"]:</strong> @localizer["Pendiente"]
</p>

<p>
    @localizer["NotificacionPago"]
</p>
