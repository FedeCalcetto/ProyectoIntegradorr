@model DetallesProductoViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Detalle del producto";

    var rol = Context.Session.GetString("Rol")?.ToUpper();
    var esCliente = rol == "CLIENTE";
}

@section Head {
    <meta property="og:type" content="product" />
    <meta property="og:title" content="@Model.Nombre" />
    <meta property="og:description" content="@(Model.Descripcion?.Length > 140 ? Model.Descripcion.Substring(0, 140) + "..." : Model.Descripcion)" />
    <meta property="og:image" content="@Model.ImagenCompartir" />
    <meta property="og:url" content="@Model.UrlCompartir" />
    <meta property="og:site_name" content="HechoXMí" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@Model.Nombre" />
    <meta name="twitter:description" content="@Model.Descripcion" />
    <meta name="twitter:image" content="@Model.ImagenCompartir" />

}

<div class="container mt-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm p-4 position-relative">

        @* ❤️ BOTÓN FAVORITO (arriba a la derecha) *@
        @if (esCliente)
        {
            <form asp-controller="Cliente"
                  asp-action="AgregarFavorito"
                  method="post"
                  class="position-absolute"
                  style="top: 14px; right: 14px; z-index: 5;">

                @Html.AntiForgeryToken()
                <input type="hidden" name="productoId" value="@Model.Id" />

                <button type="button"
                        class="fav-btn js-fav-btn @(Model.EsFavorito ? "is-fav" : "")"
                        data-producto-id="@Model.Id"
                        title="Agregar a favoritos">
                    <i class="bi @(Model.EsFavorito ? "bi-heart-fill" : "bi-heart")"></i>
                </button>
            </form>
        }

        @* 🔗 COMPARTIR *@
        <button type="button"
                class="fav-btn position-absolute"
                style="top: 14px; right: @(esCliente ? "64px" : "14px"); z-index: 5;"
                title="Compartir producto"
                onclick="compartirProducto()">
            <i class="bi bi-share"></i>
        </button>

        <!-- Breadcrumb -->
        <nav class="mb-3">
            <small class="text-muted">
                Catálogo / @Model.SubCategoria / @Model.Nombre
            </small>
        </nav>

        <div class="row g-4 align-items-start">

            <!-- MINIATURAS -->
            <div class="col-md-1 d-flex flex-column align-items-center gap-2">
                @foreach (var foto in Model.Fotos)
                {
                <img src="~/images/productos/@foto.UrlImagen.Replace("img/", "")"
                         class="img-thumbnail thumb-img"
                         style="width:60px; cursor:pointer"
                         onclick="cambiarImagen(this)" />
                }
            </div>

            <!-- IMAGEN PRINCIPAL -->
            <div class="col-md-4">
                <div class="border rounded shadow-sm p-3 text-center bg-white">
                    <img id="imagenPrincipal"
                         src="~/images/productos/@Model.Imagen"
                         class="img-fluid rounded"
                         style="max-height:420px; object-fit:contain;"
                         alt="@Model.Nombre" />
                </div>
            </div>

            <!-- INFO / COMPRA -->
            <div class="col-md-7">
                <div class="row">

                    <!-- 🧾 INFO PRODUCTO -->
                    <div class="col-md-4">

                        <h4 class="fw-semibold">@Model.Nombre</h4>

                        <p class="text-muted small mb-2">
                            @Model.Descripcion
                        </p>

                        <div class="mb-2">
                            @{
                                var promedio = Model.PromedioCalificacion;
                                var estrellasEnteras = (int)Math.Floor(promedio);
                                var tieneMedia = (promedio - estrellasEnteras) >= 0.5;
                            }

                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= estrellasEnteras)
                                {
                                    <i class="bi bi-star-fill text-warning"></i>
                                }
                                else if (i == estrellasEnteras + 1 && tieneMedia)
                                {
                                    <i class="bi bi-star-half text-warning"></i>
                                }
                                else
                                {
                                    <i class="bi bi-star text-warning"></i>
                                }
                            }

                            <small class="text-muted ms-2">
                                @Model.PromedioCalificacion.ToString("0.0")
                                (@Model.CantidadReseñas reseñas)
                            </small>
                        </div>


                        <div class="mb-3">
                            <span class="fs-3 fw-bold text-dark">
                                $@Model.Precio
                            </span>
                        </div>

                        <span class="badge bg-@(Model.Stock > 0 ? "success" : "danger") mb-3 d-inline-block">
                            Stock disponible: @Model.Stock
                        </span>

                        <p class="mt-3 text-muted">
                            Vendido por
                            <strong>
                                <a asp-controller="Usuario"
                                   asp-action="PerfilPublico"
                                   asp-route-id="@Model.ArtesanoId">
                                    @Model.Artesano
                                </a>
                            </strong>
                        </p>

                    </div>

                    <!-- ⚙️ ACCIONES -->
                    <div class="col-md-8 d-flex flex-column justify-content-center">

                        @if (Model.Stock > 0)
                        {
                            <form asp-controller="Carrito"
                                  asp-action="AgregarAlCarrito"
                                  method="post">

                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productoId" value="@Model.Id" />

                                <div class="mb-3">
                                    <label class="form-label small fw-semibold">
                                        Cantidad
                                    </label>
                                    <input type="number"
                                           name="cantidad"
                                           class="form-control form-control-sm w-75"
                                           value="1"
                                           min="1"
                                           max="@Model.Stock" />
                                </div>

                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-primary px-3">
                                        🛒 Agregar al carrito
                                    </button>

                                    <a asp-controller="Usuario"
                                       asp-action="Catalogo"
                                       class="btn btn-outline-secondary px-3">
                                        Volver a la tienda
                                    </a>
                                </div>
                            </form>
                        }
                        else
                        {
                            <p class="text-danger fw-semibold mt-3">
                                Sin stock 😢
                            </p>
                        }

                    </div>

                </div>
            </div>

            <!-- FORMULARIO DE REPORTE -->
            <hr class="my-4" />

            <div class="mt-3">
                <h6 class="fw-semibold text-danger">Reportar este producto</h6>

                <form asp-controller="Producto"
                      asp-action="ReportarProducto"
                      method="post"
                      class="mt-2">

                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Id" />

                    <div class="mb-2">
                        <textarea asp-for="Reporte.razon"
                                  class="form-control form-control-sm"
                                  rows="3"
                                  placeholder="Describa el motivo del reporte"></textarea>

                        <span asp-validation-for="Reporte.razon"
                              class="text-danger small"></span>
                    </div>

                    <button type="submit"
                            class="btn btn-sm btn-outline-danger">
                        🚩 Reportar producto
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- SCRIPTS -->
<script>
    function cambiarImagen(element) {
        const principal = document.getElementById("imagenPrincipal");
        principal.src = element.src;

        document.querySelectorAll(".thumb-img")
            .forEach(img => img.classList.remove("active-thumb"));

        element.classList.add("active-thumb");
    }

    document.addEventListener("DOMContentLoaded", () => {
        const primera = document.querySelector(".thumb-img");
        if (primera) primera.classList.add("active-thumb");
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


@* <a href="#"
   onclick="event.preventDefault(); alert('Perfil del artesano próximamente');">
    @Model.Artesano
</a> *@

<script>
    async function compartirProducto() {

        const url = @Html.Raw(JsonSerializer.Serialize(Model.UrlCompartir));
        const titulo = @Html.Raw(JsonSerializer.Serialize(Model.Nombre));

        const texto = `🧶 ${titulo}

    Mirá este producto en HechoXMí:
    ${url}`;

        try {

            if (navigator.share) {

                await navigator.share({
                    title: titulo,
                    text: texto,
                    url: url
                });

            } else {

                await navigator.clipboard.writeText(url);

                // notificación bonita
                const mensaje = document.createElement("div");
                mensaje.textContent = "Link copiado al portapapeles 📋";
                mensaje.style.position = "fixed";
                mensaje.style.bottom = "20px";
                mensaje.style.right = "20px";
                mensaje.style.background = "#212529";
                mensaje.style.color = "white";
                mensaje.style.padding = "10px 14px";
                mensaje.style.borderRadius = "8px";
                mensaje.style.zIndex = "9999";
                mensaje.style.boxShadow = "0 4px 10px rgba(0,0,0,0.2)";

                document.body.appendChild(mensaje);

                setTimeout(() => mensaje.remove(), 2000);

            }

        } catch (error) {
            console.log("No se pudo compartir:", error);
        }
    }
</script>