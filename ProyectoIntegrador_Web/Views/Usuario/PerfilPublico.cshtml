    @model PerfilPublicoViewModel
    @using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory factory
@{
    var localizer = factory.Create("Resource", "ProyectoIntegrador_Web");}
<<div class="container mt-4">

    <!-- PERFIL -->
    <div class="card mb-4">
        <div class="card-body text-center">

            @if (!string.IsNullOrEmpty(Model.Artesano.foto))
            {
                <img src="@Model.Artesano.foto"
                     class="img-fluid rounded-circle mb-3"
                     style="width:150px;height:150px;object-fit:cover;"
                     alt="@localizer["FotoDe"] @Model.Artesano.nombre" />
            }
            else
            {
                <img src="/img/default-user.png"
                     class="img-fluid rounded-circle mb-3"
                     style="width:150px;height:150px;object-fit:cover;"
                     alt="@localizer["FotoPorDefecto"]" />
            }

            <h2>@Model.Artesano.nombre</h2>
            <p class="text-muted">@Model.Artesano.descripcion</p>

            <p>
                <strong>@localizer["Telefono"]:</strong>
                @Model.Artesano.telefono
            </p>

            <!-- ⭐ RATING -->
            <div class="mt-3">

                <div class="rating-artesano"
                     data-artesano="@Model.Artesano.id">

                    @{
                        var promedio = Model.PromedioCalificacion;
                        var estrellasEnteras = (int)Math.Floor(promedio);
                        var tieneMedia = (promedio - estrellasEnteras) >= 0.5;
                    }

                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= estrellasEnteras)
                        {
                            <i class="bi bi-star-fill text-warning star-artesano"
                               data-value="@i"
                               style="cursor:pointer;font-size:1.6rem;"></i>
                        }
                        else if (i == estrellasEnteras + 1 && tieneMedia)
                        {
                            <i class="bi bi-star-half text-warning star-artesano"
                               data-value="@i"
                               style="cursor:pointer;font-size:1.6rem;"></i>
                        }
                        else
                        {
                            <i class="bi bi-star text-warning star-artesano"
                               data-value="@i"
                               style="cursor:pointer;font-size:1.6rem;"></i>
                        }
                    }

                </div>

                <div class="mt-1">
                    <small class="text-muted">
                        @localizer["Promedio"]:
                        @Model.PromedioCalificacion.ToString("0.0")
                        (@Model.CantidadReseñas @localizer["Resenas"])
                    </small>
                </div>

            </div>

        </div>
    </div>

    <!-- PRODUCTOS -->
    <h4 class="mb-3">@localizer["Productos"]</h4>

    <div class="row">
        @if (Model.Productos != null && Model.Productos.Any())
        {
            foreach (var producto in Model.Productos)
            {
                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                    <a asp-controller="Producto"
                       asp-action="DetallesProducto"
                       asp-route-id="@producto.id"
                       class="text-decoration-none text-dark">

                        <div class="card shadow-sm h-100">
                            <img src="~/images/productos/@producto.imagen"
                                 class="card-img-top"
                                 style="height:160px; object-fit:contain;"
                                 alt="@localizer["Producto"] @producto.nombre" />

                            <div class="card-body text-center">
                                <h6 class="mb-1">@producto.nombre</h6>
                                <p class="fw-bold mb-0">$@producto.precio</p>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <p class="text-muted">
                    @localizer["SinProductos"]
                </p>
            </div>
        }
    </div>

    <!-- COMENTARIOS -->
    <hr class="my-4" />

    <h4 class="mb-3">@localizer["Comentarios"]</h4>

@if (Model.Artesano.comentarios != null && Model.Artesano.comentarios.Any())
{
        <div class="list-group mb-4">
            @foreach (var comentario in Model.Artesano.comentarios)
            {
                <div class="list-group-item">
                    <p class="mb-1">@comentario.contenido</p>

                    @if (comentario.cliente != null)
                    {
                        <small class="text-muted">
                            — @comentario.cliente.nombre
                        </small>
                    }
                </div>
            }
        </div>
}
else
{
        <p class="text-muted">
            @localizer["SinComentarios"]
        </p>
}

    <!-- COMENTAR -->
    <div class="mb-4">
        <h6 class="fw-semibold">
            @localizer["DejarComentario"]
        </h6>

        <form asp-controller="Usuario"
              asp-action="ComentarArtesano"
              method="post">

            @Html.AntiForgeryToken()

            <input type="hidden" name="artesanoId" value="@Model.Artesano.id" />

            <div class="mb-2">
                <textarea asp-for="Comentario.contenido"
                          class="form-control"
                          rows="3"
                          placeholder="@localizer["PlaceholderComentario"]"></textarea>

                <span asp-validation-for="Comentario.contenido"
                      class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-sm btn-primary">
                💬 @localizer["EnviarComentario"]
            </button>
        </form>
    </div>

    <!-- REPORTE -->
    <hr class="my-4" />

    <div class="mt-3">
        <h6 class="fw-semibold text-danger">
            @localizer["ReportarArtesano"]
        </h6>

        <form asp-controller="Usuario"
              asp-action="ReportarArtesano"
              method="post"
              class="mt-2 pb-2">

            @Html.AntiForgeryToken()

            <input type="hidden" name="artesanoId" value="@Model.Artesano.id" />

            <div class="mb-2">
                <textarea asp-for="Reporte.razon"
                          class="form-control form-control-sm"
                          rows="3"
                          placeholder="@localizer["PlaceholderReporte"]"></textarea>

                <span asp-validation-for="Reporte.razon"
                      class="text-danger small"></span>
            </div>

            <button type="submit"
                    class="btn btn-sm btn-outline-danger">
                🚩 @localizer["Reportar"]
            </button>
        </form>
    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>

               document.querySelectorAll(".rating-artesano").forEach(container => {

            const artesanoId = container.dataset.artesano;

            container.querySelectorAll(".star-artesano").forEach(star => {

                star.addEventListener("click", function () {

                    const puntaje = this.dataset.value;

                    fetch('/Usuario/Calificar', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken':
                                document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify({
                            arteId: parseInt(artesanoId),
                            puntaje: parseInt(puntaje)
                        })
                    })
                    .then(response => {
                        if (response.ok) {

                            container.querySelectorAll(".star-artesano").forEach(s => {
                                if (s.dataset.value <= puntaje) {
                                    s.classList.remove("bi-star");
                                    s.classList.add("bi-star-fill");
                                } else {
                                    s.classList.remove("bi-star-fill");
                                    s.classList.add("bi-star");
                                }
                            });

                                    alert("Gracias por calificar ⭐");
                                    location.reload();

                        } else {
                            alert("No se pudo calificar.");
                        }
                    });

                });

            });

        });

        function pintarEstrellas(container, puntaje) {

            const stars = container.querySelectorAll(".star-artesano");

            stars.forEach(star => {

                if (star.getAttribute("data-value") <= puntaje) {
                    star.classList.remove("bi-star");
                    star.classList.add("bi-star-fill", "text-warning");
                } else {
                    star.classList.remove("bi-star-fill");
                    star.classList.add("bi-star");
                }

            });

        }

    </script>

}