@model ProyectoIntegrador_Web.Models.CambioPassowrdViewModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory factory
@{
    var localizer = factory.Create("Resource", "ProyectoIntegrador_Web");
    ViewData["Title"] = localizer["CambiarPassword"];
}

<div class="container py-5 d-flex justify-content-center">
    <div class="col-12 col-md-6 col-lg-4">

        <h3 class="text-center mb-4 fw-semibold">
            @localizer["CambiarPassword"]
        </h3>

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-success text-center">
                @TempData["Mensaje"]
            </div>
        }

        <form asp-action="CambioContra" method="post" class="border rounded-3 p-4 shadow-sm bg-white">
            @Html.AntiForgeryToken()

            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="passwordActual" class="form-label">
                    @localizer["PasswordActual"]
                </label>
                <input asp-for="passwordActual" type="password" class="form-control" />
                <span asp-validation-for="passwordActual" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">
                    @localizer["PasswordNueva"]
                </label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PasswordRepetida" class="form-label">
                    @localizer["RepetirPassword"]
                </label>
                <input asp-for="PasswordRepetida" type="password" class="form-control" />
                <span asp-validation-for="PasswordRepetida" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                @localizer["GuardarCambios"]
            </button>

            <div class="text-center mt-3">
                <a href="@ViewBag.ReturnUrl" class="btn btn-outline-secondary w-100">
                    @localizer["Volver"]
                </a>
            </div>

        </form>

    </div>
</div>

