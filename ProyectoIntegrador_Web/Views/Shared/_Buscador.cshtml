@model ProyectoIntegrador_Web.Models.ProductosFiltradosViewModel
@using Microsoft.Extensions.Localization
@using System.Text.Json
@inject IStringLocalizerFactory factory
@{
    var localizer = factory.Create("Resource", "ProyectoIntegrador_Web");
}
<nav class="navbar mb-4">
    <div class="container-fluid ">

        <form method="get"
              id="formBusqueda"
              class="busqueda-form d-flex align-items-center gap-2 mt-3 w-100 flex-wrap"
        >
            <!-- MODO -->
            <select class="form-select"
                    id="modoBusqueda"
                    name="ModoBusqueda">

                <option value="productos" selected="@(Model.ModoBusqueda == "productos")">
                    @localizer["Productos"]
                </option>

                <option value="usuarios" selected="@(Model.ModoBusqueda == "usuarios")">
                    @localizer["Usuarios"]
                </option>
            </select>

            <!-- TEXTO -->
            <input type="text"
                   name="Filtro"
                   id="inputBusqueda"
                   class="form-control"
                   value="@Model.Filtro"
                   placeholder="@localizer["Buscar"]"
                   
                   />

            <!-- FILTROS -->
            <div id="filtrosProductos" class="d-flex gap-2">

                <input type="number"
                       name="PrecioMin"
                       class="form-control"
                       value="@Model.PrecioMin"
                       placeholder="@localizer["PrecioMin"]"
                        />

                <input type="number"
                       name="PrecioMax"
                       class="form-control"
                       value="@Model.PrecioMax"
                       placeholder="@localizer["PrecioMax"]"
                        />

                <select id="categoriaSelect"
                        name="CategoriaId"
                        class="form-select"
                        >
                    <option value="">@localizer["Categorias"]</option>

                    @foreach (var c in Model.Categorias ?? Enumerable.Empty<ProyectoIntegrador.LogicaNegocio.Entidades.Categoria>())
                    {
                        <option value="@c.Id" selected="@(Model.CategoriaId == c.Id)">
                            @c.Nombre
                        </option>
                    }
                </select>

                <select id="subcategoriaSelect"
                        name="SubCategoriaId"
                        class="form-select"
                        
                        @(Model.CategoriaId == null ? "disabled" : "")>

                    <option value="">@localizer["Subcategorias"]</option>

                    @foreach (var s in Model.SubCategorias ?? Enumerable.Empty<ProyectoIntegrador.LogicaNegocio.Entidades.SubCategoria>())
                    {
                        <option value="@s.Id" selected="@(Model.SubCategoriaId == s.Id)">
                            @s.Nombre
                        </option>
                    }
                </select>
            </div>

            <!-- BOTÓN -->
            <button id="botonBuscar"  class="btn btn-primary px-4">
                @localizer["Buscar"]
            </button>

        </form>
    </div>
</nav>
<script>
    document.addEventListener('DOMContentLoaded', function () {

        const form = document.getElementById('formBusqueda');
        const modo = document.getElementById('modoBusqueda');
        const filtros = document.getElementById('filtrosProductos');
        const input = document.getElementById('inputBusqueda');

        const placeholderUsuarios = @Html.Raw(JsonSerializer.Serialize(localizer["BuscarUsuarios"].Value));
        const placeholderProductos = @Html.Raw(JsonSerializer.Serialize(localizer["BuscarProductos"].Value));

        const urlUsuarios = '@Url.Action("BusquedaDeUsuarios", "Usuario")';
        const urlProductos = '@Url.Action("ProductosFiltrados", "Producto")';

        function actualizarModo() {
            if (modo.value === 'usuarios') {
                filtros.classList.add('d-none');
                filtros.classList.remove('d-flex');
                form.action = urlUsuarios;
                input.placeholder = placeholderUsuarios;
            } else {
                filtros.classList.remove('d-none');
                filtros.classList.add('d-flex');
                form.action = urlProductos;
                input.placeholder = placeholderProductos;
            }
        }

        modo.addEventListener('change', actualizarModo);
        actualizarModo();

        const categoriaSelect = document.getElementById("categoriaSelect");
        const subcategoriaSelect = document.getElementById("subcategoriaSelect");

        if (categoriaSelect) {
            categoriaSelect.addEventListener("change", function () {
                const categoriaId = this.value;

                subcategoriaSelect.innerHTML =
                    `<option value="">${@Html.Raw(JsonSerializer.Serialize(localizer["Subcategorias"].Value))}</option>`;

                subcategoriaSelect.disabled = true;

                if (!categoriaId) return;

                fetch(`/Producto/GetSubcategorias?categoriaId=${categoriaId}`)
                    .then(r => r.json())
                    .then(data => {
                        data.forEach(s => {
                            const option = document.createElement("option");
                            option.value = s.id;
                            option.textContent = s.nombre;
                            subcategoriaSelect.appendChild(option);
                        });
                        subcategoriaSelect.disabled = false;
                    });
            });
        }
    });
</script>