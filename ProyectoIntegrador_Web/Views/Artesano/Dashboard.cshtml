@using Microsoft.Extensions.Localization
@using ProyectoIntegrador_Web.Resources
@inject IStringLocalizer<SharedResource> Localizer
@model DashboardViewModel

@{
    ViewData["Title"] = Localizer["DashboardArtesano"];
}

<h2 class="mb-4">📊 @Localizer["Dashboard"]</h2>
<p>@System.Globalization.CultureInfo.CurrentUICulture</p>
@Localizer["TotalVentas"].ResourceNotFound
<!-- ===================== -->
<!-- KPIs -->
<!-- ===================== -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h6>@Localizer["TotalVentas"]</h6>
                <h3>@Model.CantidadVentasTotal</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h6>@Localizer["VentasMes"]</h6>
                <h3>@Model.CantidadVentasMesActual</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h6>@Localizer["VentasAño"]</h6>
                <h3>@Model.CantidadVentasAnoActual</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h6>@Localizer["VariaciónMensual"]</h6>
                <h3 class="@(Model.VariacionVentasMensual >= 0 ? "text-success" : "text-danger")">
                    @Model.VariacionVentasMensual.ToString("0.##") %
                </h3>
            </div>
        </div>
    </div>
</div>

<!-- ===================== -->
<!-- TOP PRODUCTOS -->
<!-- ===================== -->
<div class="row mb-4">
    <div class="col-md-6">
        <h4>🔥 @Localizer["ProductosMásVendidos"]</h4>

        @if (Model.TopProductosVentas.Any())
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@Localizer["Producto"]</th>
                        <th>@Localizer["CantidadVendida"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var producto in Model.TopProductosVentas)
                    {
                        <tr>
                            <td>@producto.NombreProducto</td>
                            <td>@producto.CantidadVendida</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">@Localizer["NoVentasRegistradas"]</p>
        }
    </div>
</div>

<!-- ===================== -->
<!-- GRAFICO -->
<!-- ===================== -->
<div class="row">
    <div class="col-md-12">
        <h4>📈 @Localizer["VentasPorMes"]</h4>
        <canvas id="ventasPorMesChart" height="100"></canvas>
    </div>
</div>

<!-- ===================== -->
<!-- SCRIPTS -->
<!-- ===================== -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener("DOMContentLoaded", function () {

    const labels = @Html.Raw(
        System.Text.Json.JsonSerializer.Serialize(
            Model.GraficoVentas.Select(x => $"{x.Mes}/{x.Ano}")
        )
    );

    const data = @Html.Raw(
        System.Text.Json.JsonSerializer.Serialize(
            Model.GraficoVentas.Select(x => x.Cantidad)
        )
    );

    console.log(labels, data);

    const canvas = document.getElementById('ventasPorMesChart');
    if (!canvas) {
        console.error("No se encontró el canvas");
        return;
    }

    const ctx = canvas.getContext('2d');

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
    label: '@Localizer["Ventas"]',
    data: data,
                tension: 0.3,
                fill: false
            }]
        },
        options: {
            responsive: true,
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { precision: 0 }
                }
            }
        }
    });

});
</script>
