@model ProyectoIntegrador_Web.Models.EditarArtesanoViewModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory factory

@{
    var localizer = factory.Create("Resource", "ProyectoIntegrador_Web");
    ViewData["Title"] = localizer["Perfil"];
}

<div class="layout">

    <div class="barraLateral">
        <div class="sidebar">
            <p>@localizer["OtrasOpciones"]</p>

            <div class="mb-3 d-flex justify-content-left">
                <a asp-controller="Usuario"
                   asp-action="CambioContra"
                   asp-route-returnUrl="/Artesano/PerfilArtesano"
                   class="btn btn-outline-secondary">
                    @localizer["NuevaContrasena"]
                </a>
            </div>

            <div class="d-flex justify-content-left mt-4">
                <button type="button"
                        class="btn btn-danger"
                        data-bs-toggle="modal"
                        data-bs-target="#modalEliminarCuenta"
                        onclick="pedirCodigoEliminarArtesano()">
                    @localizer["EliminarCuenta"]
                </button>
            </div>
        </div>
    </div>

    <div class="contenido py-5">

        <h2 class="text-center mb-3 fw-semibold" style="color: black;">
            @localizer["MiPerfil"]
        </h2>

        <p class="text-center text-muted mb-4">
            @localizer["ActualizarDatosPersonales"]
        </p>

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <form asp-action="PerfilArtesano" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- FOTO -->
            <div class="d-flex justify-content-center mb-2">
                <img id="fotoPerfil"
                     src="@(string.IsNullOrEmpty(Model.Foto)
                                                                  ? "/images/usuarios/default-image.jpg"
                                                                  : Model.Foto)"
                     class="img-thumbnail shadow foto-perfil">
            </div>

            <div class="text-center mb-3">
                <label class="btn btn-outline-secondary">
                    @localizer["SeleccionarFoto"]
                    <input id="archivoFoto" type="file" name="archivoFoto" accept="image/*" hidden />
                </label>

                <div id="archivoSeleccionado" class="mt-2 text-muted"></div>
            </div>

            <!-- CAMPOS -->
            <input type="hidden" asp-for="Foto" />

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-semibold"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Apellido" class="form-label fw-semibold"></label>
                <input asp-for="Apellido" class="form-control" />
                <span asp-validation-for="Apellido" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Telefono" class="form-label fw-semibold"></label>
                <input asp-for="Telefono" class="form-control" />
                <span asp-validation-for="Telefono" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold"></label>
                <input asp-for="Email" class="form-control bg-light" readonly />
            </div>

            <input type="hidden" asp-for="Password" />

            <!-- BOTONES -->
            <div class="d-flex justify-content-between">
                <a asp-action="FacturasArtesano"
                   asp-controller="FacturaNoFiscal"
                   class="btn btn-outline-secondary">
                    @localizer["Volver"]
                </a>

                <button type="submit" class="btn btn-primary">
                    @localizer["GuardarCambios"]
                </button>
            </div>

        </form>

        @if (Model.EliminarCuenta != null)
        {
            @await Html.PartialAsync("_ModalEliminarCuenta", Model.EliminarCuenta)
        }

        <script>
            function pedirCodigoEliminarArtesano() {
                fetch('/Artesano/PedirCodigoEliminar', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken':
                            document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });
            }
        </script>

        <script>
            const input = document.getElementById("archivoFoto");
            const preview = document.getElementById("fotoPerfil");
            const archivoLabel = document.getElementById("archivoSeleccionado");

            input.addEventListener("change", function () {
                if (this.files && this.files[0]) {
                    const archivo = this.files[0];
                    archivoLabel.innerHTML = `<strong>${archivo.name}</strong>`;

                    const reader = new FileReader();
                    reader.onload = e => preview.src = e.target.result;
                    reader.readAsDataURL(archivo);
                }
            });
        </script>

        @if (TempData["ErrorEliminar"] != null)
        {
            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    const modal = new bootstrap.Modal(
                        document.getElementById("modalEliminarCuenta")
                    );
                    modal.show();
                });
            </script>
        }

    </div>
</div>

