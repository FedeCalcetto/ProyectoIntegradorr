@model ProyectoIntegrador_Web.Models.NuevaPasswordViewModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory factory

@{
    var localizer = factory.Create("Resource", "ProyectoIntegrador_Web");
    ViewData["Title"] = localizer["CambiarContrasena"];
}

<form asp-action="NuevaPassword" method="post">
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="container mt-4" style="max-width: 400px;">
        <h4 class="mb-3">@localizer["Contrasena"]</h4>

        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <!-- Nueva contraseña -->
        <div class="form-group position-relative mb-3">
            <label class="form-label">@localizer["ContrasenaNueva"]</label>

            <input asp-for="Password"
                   type="password"
                   class="form-control password-input"
                   placeholder="@localizer["PlaceholderContrasenaNueva"]" />

            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <!-- Confirmar -->
        <div class="form-group position-relative mb-4">
            <label class="form-label">@localizer["ConfirmarContrasenaNueva"]</label>

            <input asp-for="ConfirmPassword"
                   type="password"
                   class="form-control password-input"
                   placeholder="@localizer["PlaceholderConfirmarContrasena"]" />

            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">
                @localizer["CambiarContrasena"]
            </button>

            <a asp-action="PerfilArtesano" id="volverArtesano" class="btn btn-outline-secondary">
                @localizer["Volver"]
            </a>
        </div>
    </div>
</form>
