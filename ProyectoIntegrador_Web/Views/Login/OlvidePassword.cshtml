@model ForgotPasswordViewModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory factory

@{
    var localizer = factory.Create("Resource", "ProyectoIntegrador_Web");
    ViewData["Title"] = localizer["RecuperarPassword"];
    Layout = "_LayoutLogin";
}

<div class="login-wrapper">

    <div class="login-card">

        <!-- IZQUIERDA -->
        <div class="login-form">

            <h6 class="brand">HechoXMí</h6>

            <h2>Recuperar contraseña</h2>
            <p>Ingresá tu correo y te mandamos un enlace seguro 🔐</p>

            @if (TempData["Mensaje"] != null)
            {
                var tipo = TempData["TipoMensaje"]?.ToString() ?? "success";

                <div class="alert alert-@tipo alert-dismissible fade show small" role="alert">
                    @TempData["Mensaje"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="OlvidePassword"
                  method="post"
                  class="js-loader"
                  data-loader-text="Enviando enlace...">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                <div class="mb-3">
                    <input asp-for="Email"
                           class="form-control"
                           placeholder="Email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-dark w-100">
                    Enviar enlace
                </button>

                <!-- VOLVER -->
                <div class="text-center mt-3">
                    <a asp-action="Login" class="small text-decoration-none">
                        ← Volver al login
                    </a>
                </div>

            </form>

        </div>

        <!-- DERECHA (IMAGEN) -->
        <div class="login-image">
            <div class="image-overlay"></div>
        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<script>
    const images = [
        "/images/login/seguridad1.jpg",
        "/images/login/seguridad2.jpg"
    ];

    let index = 0;
    const imageDiv = document.querySelector(".login-image");

    function changeImage() {
        imageDiv.style.backgroundImage = `url('${images[index]}')`;
        index = (index + 1) % images.length;
    }

    changeImage();
    setInterval(changeImage, 5000);
</script>
