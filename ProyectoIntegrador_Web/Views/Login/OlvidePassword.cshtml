@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Recuperar contraseña";
    Layout = "_LayoutLogin";
}

<div class="registro-card single">
    <div class="registro-form">
        <h2>Recuperar contraseña</h2>
        <p>Ingresá tu correo y te mandamos un enlace.</p>

        <form asp-action="OlvidePassword" method="post" class="js-loader" data-loader-text="Enviando...">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <div class="mb-3">
                <input asp-for="Email" class="form-control" placeholder="Email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-dark w-100">Enviar enlace</button>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }