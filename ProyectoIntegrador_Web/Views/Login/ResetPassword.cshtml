@model ResetPasswordViewModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory factory

@{
    var localizer = factory.Create("Resource", "ProyectoIntegrador_Web");
    ViewData["Title"] = localizer["RestablecerPassword"];
    Layout = "_LayoutLogin";
}

<div class="login-layout">

    <div class="registro-card single p-4">

        <div class="registro-form text-center">
            <h2 class="mb-2">Nueva contraseña</h2>
            <p class="text-muted small mb-4">
                Elegí una contraseña segura 🔐
            </p>

            @if (TempData["Mensaje"] != null)
            {
                var tipo = TempData["TipoMensaje"]?.ToString() ?? "success";

                <div class="alert alert-@tipo alert-dismissible fade show small" role="alert">
                    @TempData["Mensaje"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="ResetPassword"
                  method="post"
                  class="js-loader"
                  data-loader-text="Actualizando contraseña...">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                <input asp-for="Token" type="hidden" />

                <!-- PASSWORD -->
                <div class="mb-3 text-start">
                    <input asp-for="NuevaPassword"
                           type="password"
                           class="form-control"
                           placeholder="Nueva contraseña"
                           id="passwordInput" />
                    <span asp-validation-for="NuevaPassword" class="text-danger small"></span>
                </div>

                <!-- BARRA SEGURIDAD -->
                <div class="mb-2">
                    <div class="progress" style="height: 8px;">
                        <div id="passwordStrengthBar"
                             class="progress-bar"
                             style="width: 0%">
                        </div>
                    </div>

                    <small id="passwordStrengthText" class="text-muted"></small>
                </div>

                <!-- REGLAS -->
                <div id="passwordHelp" class="small text-muted mb-3"></div>

                <!-- REPETIR -->
                <div class="mb-3 text-start">
                    <input asp-for="RepetirPassword"
                           type="password"
                           class="form-control"
                           placeholder="Repetir contraseña" />
                    <span asp-validation-for="RepetirPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-dark w-100">
                    Cambiar contraseña
                </button>

                <div class="mt-3">
                    <a asp-action="Login" class="small text-decoration-none">
                        ← Volver al login
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


<script>
    const passwordInput = document.getElementById("passwordInput");
    const bar = document.getElementById("passwordStrengthBar");
    const text = document.getElementById("passwordStrengthText");
    const help = document.getElementById("passwordHelp");

    passwordInput.addEventListener("input", () => {
        const value = passwordInput.value;
        let score = 0;
        let reglas = [];

        if (value.length >= 10 && value.length <= 30) {
            score++;
        } else {
            reglas.push("• 10 a 30 caracteres");
        }

        if (/[A-Z]/.test(value) && /[a-z]/.test(value)) {
            score++;
        } else {
            reglas.push("• Mayúsculas y minúsculas");
        }

        if (/[0-9]/.test(value)) {
            score++;
        } else {
            reglas.push("• Al menos un número");
        }

        let width = "0%";
        let clase = "bg-danger";
        let mensaje = "";

        if (score === 1) {
            width = "33%";
            mensaje = "Débil";
        } else if (score === 2) {
            width = "66%";
            clase = "bg-warning";
            mensaje = "Media";
        } else if (score === 3) {
            width = "100%";
            clase = "bg-success";
            mensaje = "Fuerte";
        }

        bar.style.width = width;
        bar.className = `progress-bar ${clase}`;

        text.textContent = value ? `Seguridad: ${mensaje}` : "";
        help.innerHTML = reglas.join("<br>");
    });
</script>