@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Restablecer contraseña";
    Layout = "_LayoutLogin";
}

<div class="registro-card single">
    <div class="registro-form">
        <h2>Nueva contraseña</h2>

        <form asp-action="ResetPassword" method="post" class="js-loader" data-loader-text="Actualizando...">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <input asp-for="Token" type="hidden" />

            <div class="mb-3">
                <input asp-for="NuevaPassword" type="password" class="form-control" placeholder="Nueva contraseña" />
            </div>

            <div class="mb-3">
                <input asp-for="RepetirPassword" type="password" class="form-control" placeholder="Repetir contraseña" />
            </div>

            <button type="submit" class="btn btn-dark w-100">Cambiar contraseña</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}