@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory factory

@{
    var localizer = factory.Create("Resource", "ProyectoIntegrador_Web");
    ViewBag.Title = localizer["VerificarEmail"];
}

<div class="d-flex justify-content-center mt-5">
    <div class="card shadow-lg p-4" style="max-width: 420px; width: 100%; border-radius: 18px;">

        <div class="text-center mb-3">
            <i class="bi bi-shield-lock-fill text-primary" style="font-size: 3rem;"></i>
            <h3 class="mt-2">@localizer["VerificacionCorreo"]</h3>
        </div>

        @* MENSAJE DE ÉXITO *@
        @if (ViewBag.Mensaje != null)
        {
            <div class="alert alert-success text-center">
                <i class="bi bi-check-circle-fill"></i> @ViewBag.Mensaje
            </div>
        }

        @* MENSAJE DE ERROR *@
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center">
                <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
            </div>
        }

        @* FORMULARIO SOLO SI NO ESTÁ VERIFICADO *@
        @if (ViewBag.Mensaje == null)
        {
            <p class="text-muted text-center">
                @localizer["IngresarCodigoEmail"]
            </p>

            <form method="post" action="/Login/VerificarEmail">
                <input type="hidden" name="email" value="@ViewBag.Email" />

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        @localizer["CodigoVerificacion"]
                    </label>

                    <input type="text"
                           name="codigo"
                           class="form-control form-control-lg text-center"
                           placeholder="@localizer["EjemploCodigo"]"
                           maxlength="6"
                           required />
                </div>

                <button class="btn btn-primary w-100 btn-lg mb-2">
                    <i class="bi bi-unlock-fill"></i>
                    @localizer["VerificarCodigo"]
                </button>
            </form>

            <form method="post" action="/Login/ReenviarCodigo" class="text-center">
                <input type="hidden" name="email" value="@ViewBag.Email" />

                <button class="btn btn-outline-warning w-100 mt-2">
                    <i class="bi bi-arrow-repeat"></i>
                    @localizer["ReenviarCodigo"]
                </button>
            </form>

            <div class="text-center mt-3">
                <small class="text-muted">
                    @localizer["NoVesCorreo"] <strong>@localizer["Spam"]</strong>.
                </small>
            </div>
        }
    </div>
</div>