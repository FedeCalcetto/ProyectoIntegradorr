@model ProyectoIntegrador_Web.Models.LoginViewModel
@inject IConfiguration Configuration
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory factory

@{
    var localizer = factory.Create("Resource", "ProyectoIntegrador_Web");
    Layout = "_LayoutLogin";
    ViewData["BodyClass"] = "login-body";
    ViewData["Title"] = localizer["Login"];
}

<div class="login-stack">

    @if (TempData["Mensaje"] != null)
    {
        var tipo = TempData["TipoMensaje"]?.ToString() ?? "success";

        <div class="login-alert">
            <div class="alert alert-@tipo alert-dismissible fade show shadow-sm"
                 role="alert">
                @TempData["Mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <div class="login-wrapper">
        <div class="login-card">

            <!-- COLUMNA IZQUIERDA -->
            <div class="login-form">
                <h6 class="brand">HechoXMí</h6>
                <h2>@localizer["Bienvenido"]</h2>
                <p>@localizer["IngresarCredenciales"]</p>

                <form asp-controller="Login" asp-action="Login" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                    <div class="mb-3">
                        <input asp-for="Email"
                               class="form-control"
                               placeholder="@localizer["Email"]" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               placeholder="@localizer["Password"]" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-dark w-100">
                        @localizer["Ingresar"]
                    </button>

                    <div class="text-center mt-2">
                        <a asp-controller="Login"
                           asp-action="OlvidePassword"
                           class="small text-decoration-none">
                            @localizer["OlvidoPassword"]
                        </a>
                    </div>

                    <p class="mt-3 text-center">
                        @localizer["NoTenesCuenta"]
                        <a asp-action="registroUsuario">
                            @localizer["Registrate"]
                        </a>
                    </p>

                    <div class="d-flex justify-content-center mt-3 mb-3 recaptcha-wrapper">
                        <div class="g-recaptcha" data-sitekey="@Configuration["GoogleReCaptcha:SiteKey"]"></div>
                    </div>

                    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
                </form>
            </div>

            <!-- COLUMNA DERECHA -->
            <div class="login-image">
                <div class="image-overlay"></div>
            </div>

        </div>
    </div>

</div>

<script>
    const images = [
        "/images/login/ParaLogin1.jpg",
        "/images/login/ParaLogin2.jpg"
    ];

    let index = 0;
    const imageDiv = document.querySelector(".login-image");

    function changeImage() {
        imageDiv.style.backgroundImage = `url('${images[index]}')`;
        index = (index + 1) % images.length;
    }

    changeImage();
    setInterval(changeImage, 5000);
</script>