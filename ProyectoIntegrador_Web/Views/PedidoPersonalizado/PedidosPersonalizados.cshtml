@using ProyectoIntegrador.LogicaNegocio.Entidades
@using ProyectoIntegrador_Web.Models
@model PedidosPersonalizadosPaginadosViewModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory factory

@{
    var localizer = factory.Create("Resource", "ProyectoIntegrador_Web");
}

<div class="container mt-4">
    <h2 class="mb-4 text-center fw-bold">
        @localizer["PedidosPersonalizados"]
    </h2>

    <form method="get" class="row mb-4">
        <div class="col-md-6">
            <input type="text"
                   name="busqueda"
                   value="@Model.Busqueda"
                   class="form-control"
                   placeholder="@localizer["BuscarPedidoPlaceholder"]" />
        </div>

        <div class="col-md-4">
            <select name="orden" class="form-select">
                <option value="fecha_desc" selected="@(Model.Orden == "fecha_desc")">
                    @localizer["MasRecientes"]
                </option>
                <option value="fecha_asc" selected="@(Model.Orden == "fecha_asc")">
                    @localizer["MasAntiguos"]
                </option>
                <option value="nombre_asc" selected="@(Model.Orden == "nombre_asc")">
                    @localizer["ClienteAZ"]
                </option>
                <option value="nombre_desc" selected="@(Model.Orden == "nombre_desc")">
                    @localizer["ClienteZA"]
                </option>
            </select>
        </div>

        <div class="col-md-2">
            <button class="btn btn-primary w-100">
                @localizer["Buscar"]
            </button>
        </div>
    </form>

    @if (Model.Pedidos.Any())
    {
        foreach (var p in Model.Pedidos)
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">@p.Titulo</h5>
                    <p class="card-text">@p.Descripcion</p>

                    <p class="text-muted mb-2">
                        @localizer["PedidoPor"]:
                        <strong>@p.Cliente.nombre @p.Cliente.apellido</strong><br />
                        @localizer["Fecha"]:
                        @p.FechaCreacion.ToShortDateString()
                    </p>

                    <form asp-action="Aceptar"
                          method="post"
                          class="js-loader"
                          data-loader-text="@localizer["AceptandoPedido"]">

                        <input type="hidden" name="id" value="@p.Id" />

                        <button class="btn btn-success">
                            @localizer["AceptarEncargo"]
                        </button>
                    </form>
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-center text-muted">
            @localizer["SinPedidosDisponibles"]
        </p>
    }

    @if (Model.TotalPaginas > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">

                <li class="page-item @(Model.PaginaActual == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="PedidosPersonalizados"
                       asp-route-pagina="@(Model.PaginaActual - 1)"
                       asp-route-busqueda="@Model.Busqueda"
                       asp-route-orden="@Model.Orden">
                        @localizer["Anterior"]
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPaginas; i++)
                {
                    <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                        <a class="page-link"
                           asp-action="PedidosPersonalizados"
                           asp-route-pagina="@i"
                           asp-route-busqueda="@Model.Busqueda"
                           asp-route-orden="@Model.Orden">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.PaginaActual == Model.TotalPaginas ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="PedidosPersonalizados"
                       asp-route-pagina="@(Model.PaginaActual + 1)"
                       asp-route-busqueda="@Model.Busqueda"
                       asp-route-orden="@Model.Orden">
                        @localizer["Siguiente"]
                    </a>
                </li>

            </ul>
        </nav>
    }
</div>

@* <script>
    setInterval(() => {
        location.reload();
    }, 1500);
</script> *@
