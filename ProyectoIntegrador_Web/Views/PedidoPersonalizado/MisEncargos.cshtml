@using ProyectoIntegrador.LogicaNegocio.Entidades
@using ProyectoIntegrador_Web.Models
@model MisEncargosPaginadosViewModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory factory

@{
    var localizer = factory.Create("Resource", "ProyectoIntegrador_Web");
}

<div class="container mt-4">
    <h2 class="mb-4 text-center fw-bold">
        @localizer["MisEncargos"]
    </h2>

    @if (Model.Pedidos.Any())
    {
        foreach (var p in Model.Pedidos)
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">@p.Titulo</h5>
                    <p class="card-text">@p.Descripcion</p>

                    <p class="text-muted mb-2">
                        @localizer["Cliente"]:
                        <strong>@p.Cliente.nombre @p.Cliente.apellido</strong><br />
                        @localizer["Estado"]:
                        <strong>@p.Estado</strong>
                    </p>

                    @if (p.Estado == EstadoPedido.Aceptado)
                    {
                        <form asp-action="Finalizar" method="post">
                            <input type="hidden" name="id" value="@p.Id" />
                            <button class="btn btn-primary">
                                @localizer["FinalizarPedido"]
                            </button>
                        </form>
                    }
                    else if (p.Estado == EstadoPedido.Finalizado)
                    {
                        <span class="badge bg-success">
                            @localizer["PedidoFinalizado"]
                        </span>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-center text-muted">
            @localizer["SinEncargosAceptados"]
        </p>
    }

    @if (Model.TotalPaginas > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">

                <li class="page-item @(Model.PaginaActual == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="MisEncargos"
                       asp-route-pagina="@(Model.PaginaActual - 1)">
                        @localizer["Anterior"]
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPaginas; i++)
                {
                    <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                        <a class="page-link"
                           asp-action="MisEncargos"
                           asp-route-pagina="@i">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.PaginaActual == Model.TotalPaginas ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="MisEncargos"
                       asp-route-pagina="@(Model.PaginaActual + 1)">
                        @localizer["Siguiente"]
                    </a>
                </li>

            </ul>
        </nav>
    }
</div>